{
    "openapi": "3.1.0",
    "info": {
        "title": "Ticket Booking System API",
        "description": "Backend API for booking event tickets with a hold-then-confirm reservation pattern. Supports temporary seat holds, booking confirmation, automatic hold expiry, and concurrent booking safety via pessimistic locking.",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8080",
            "description": "Generated server url"
        }
    ],
    "tags": [
        {
            "name": "Holds",
            "description": "Temporary seat reservation management"
        },
        {
            "name": "Bookings",
            "description": "Booking confirmation and management"
        },
        {
            "name": "Events",
            "description": "Event management and availability"
        }
    ],
    "paths": {
        "/api/v1/events/{eventId}": {
            "get": {
                "tags": [
                    "Events"
                ],
                "summary": "Get event by ID",
                "operationId": "getEvent",
                "parameters": [
                    {
                        "name": "eventId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/EventResponse"
                                }
                            }
                        }
                    }
                }
            },
            "put": {
                "tags": [
                    "Events"
                ],
                "summary": "Update event details",
                "description": "Updates event name, description, location, and date. Total seats cannot be changed.",
                "operationId": "updateEvent",
                "parameters": [
                    {
                        "name": "eventId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/UpdateEventRequest"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/EventResponse"
                                }
                            }
                        }
                    }
                }
            },
            "delete": {
                "tags": [
                    "Events"
                ],
                "summary": "Delete event",
                "description": "Fails if event has active holds or confirmed bookings",
                "operationId": "deleteEvent",
                "parameters": [
                    {
                        "name": "eventId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            }
        },
        "/api/v1/events": {
            "get": {
                "tags": [
                    "Events"
                ],
                "summary": "List all events",
                "operationId": "getAllEvents",
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/EventResponse"
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "tags": [
                    "Events"
                ],
                "summary": "Create a new event",
                "description": "Creates an event and auto-generates numbered seat rows",
                "operationId": "createEvent",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/CreateEventRequest"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/EventResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/events/{eventId}/holds": {
            "post": {
                "tags": [
                    "Holds"
                ],
                "summary": "Hold specific seats",
                "description": "Creates a 5-minute temporary reservation on the specified seats. Returns a holdId for confirmation.",
                "operationId": "holdSeats",
                "parameters": [
                    {
                        "name": "eventId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/HoldSeatsRequest"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/HoldResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/bookings": {
            "post": {
                "tags": [
                    "Bookings"
                ],
                "summary": "Confirm booking from hold",
                "description": "Converts a valid hold into a permanent booking. Hold must be ACTIVE and not expired.",
                "operationId": "confirmBooking",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ConfirmBookingRequest"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/BookingResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/bookings/{bookingReference}/cancel": {
            "patch": {
                "tags": [
                    "Bookings"
                ],
                "summary": "Cancel booking",
                "description": "Soft-deletes the booking (marks as CANCELED) and releases seats back to AVAILABLE",
                "operationId": "cancelBooking",
                "parameters": [
                    {
                        "name": "bookingReference",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/BookingResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/users/{userId}/bookings": {
            "get": {
                "tags": [
                    "Bookings"
                ],
                "summary": "Get all bookings for a user",
                "operationId": "getUserBookings",
                "parameters": [
                    {
                        "name": "userId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/BookingResponse"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/holds/{holdId}": {
            "get": {
                "tags": [
                    "Holds"
                ],
                "summary": "Get hold status",
                "description": "Returns hold details including held seat numbers and expiry time",
                "operationId": "getHold",
                "parameters": [
                    {
                        "name": "holdId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/HoldResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/events/{eventId}/availability": {
            "get": {
                "tags": [
                    "Events"
                ],
                "summary": "Get seat availability",
                "description": "Returns event details with per-seat status breakdown (AVAILABLE, HELD, BOOKED)",
                "operationId": "getAvailability",
                "parameters": [
                    {
                        "name": "eventId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/EventAvailabilityResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/bookings/{bookingReference}": {
            "get": {
                "tags": [
                    "Bookings"
                ],
                "summary": "Get booking details",
                "operationId": "getBooking",
                "parameters": [
                    {
                        "name": "bookingReference",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/BookingResponse"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "UpdateEventRequest": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string",
                        "minLength": 1
                    },
                    "description": {
                        "type": "string"
                    },
                    "location": {
                        "type": "string",
                        "minLength": 1
                    },
                    "eventDate": {
                        "type": "string",
                        "format": "date-time"
                    }
                },
                "required": [
                    "eventDate"
                ]
            },
            "EventResponse": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "name": {
                        "type": "string"
                    },
                    "description": {
                        "type": "string"
                    },
                    "location": {
                        "type": "string"
                    },
                    "eventDate": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "totalSeats": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "createdAt": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "updatedAt": {
                        "type": "string",
                        "format": "date-time"
                    }
                }
            },
            "CreateEventRequest": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string",
                        "minLength": 1
                    },
                    "description": {
                        "type": "string"
                    },
                    "location": {
                        "type": "string",
                        "minLength": 1
                    },
                    "eventDate": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "totalSeats": {
                        "type": "integer",
                        "format": "int32"
                    }
                },
                "required": [
                    "eventDate",
                    "totalSeats"
                ]
            },
            "HoldSeatsRequest": {
                "type": "object",
                "properties": {
                    "userId": {
                        "type": "string",
                        "minLength": 1
                    },
                    "seatNumbers": {
                        "type": "array",
                        "items": {
                            "type": "string",
                            "minLength": 1
                        },
                        "maxItems": 10,
                        "minItems": 0
                    }
                }
            },
            "HoldResponse": {
                "type": "object",
                "properties": {
                    "holdId": {
                        "type": "string",
                        "format": "uuid"
                    },
                    "eventId": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "userId": {
                        "type": "string"
                    },
                    "heldSeats": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "status": {
                        "type": "string",
                        "enum": [
                            "ACTIVE",
                            "CONFIRMED",
                            "EXPIRED"
                        ]
                    },
                    "expiresAt": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "createdAt": {
                        "type": "string",
                        "format": "date-time"
                    }
                }
            },
            "ConfirmBookingRequest": {
                "type": "object",
                "properties": {
                    "holdId": {
                        "type": "string",
                        "format": "uuid"
                    }
                },
                "required": [
                    "holdId"
                ]
            },
            "BookingResponse": {
                "type": "object",
                "properties": {
                    "bookingReference": {
                        "type": "string",
                        "format": "uuid"
                    },
                    "eventId": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "userId": {
                        "type": "string"
                    },
                    "bookedSeats": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "status": {
                        "type": "string",
                        "enum": [
                            "CONFIRMED",
                            "CANCELED"
                        ]
                    },
                    "createdAt": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "canceledAt": {
                        "type": "string",
                        "format": "date-time"
                    }
                }
            },
            "EventAvailabilityResponse": {
                "type": "object",
                "properties": {
                    "eventId": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "eventName": {
                        "type": "string"
                    },
                    "eventDate": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "location": {
                        "type": "string"
                    },
                    "totalSeats": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "availableCount": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "heldCount": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "bookedCount": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "seats": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/SeatDetail"
                        }
                    }
                }
            },
            "SeatDetail": {
                "type": "object",
                "properties": {
                    "seatNumber": {
                        "type": "string"
                    },
                    "status": {
                        "type": "string",
                        "enum": [
                            "AVAILABLE",
                            "HELD",
                            "BOOKED"
                        ]
                    }
                }
            }
        }
    }
}
